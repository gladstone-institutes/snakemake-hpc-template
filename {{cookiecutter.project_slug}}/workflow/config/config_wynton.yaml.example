# {{ cookiecutter.project_name }} - Wynton HPC production config.
#
# Run on the cluster:
#   snakemake --snakefile workflow/Snakefile \
#       --configfile workflow/config/config_wynton.yaml \
#       --profile workflow/profiles/sge
#
# Non-Gladstone users: edit `containers.bind_paths` below to point at your
# shared storage instead of /gladstone/bioinformatics.

project_name: "{{ cookiecutter.project_slug }}"

execution:
  use_docker: false
  use_apptainer: true

notification:
  email: "{{ cookiecutter.wynton_account_email }}"

# Wynton-writable output directory. TODO: edit to your project path.
output_dir: "/wynton/scratch/{{ cookiecutter.author_email.split('@')[0] }}/{{ cookiecutter.project_slug }}/results"

samples: "workflow/config/samples.tsv"

containers:
  # Directory of pre-pulled .sif files. Shared across runs/users if you want.
  dir: "/wynton/scratch/{{ cookiecutter.author_email.split('@')[0] }}/{{ cookiecutter.project_slug }}/containers"
  auto_pull: true
  # Paths to bind into Apptainer containers. Default is Gladstone-specific;
  # edit or add entries as needed.
  bind_paths:
    - "/gladstone/bioinformatics"
    - "/wynton/scratch"
  images:
    hello:
      user: "{{ cookiecutter.docker_username }}"
      name: "hello"
      tag: "0.1.0"
