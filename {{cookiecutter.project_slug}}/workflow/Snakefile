# {{ cookiecutter.project_name }} Snakemake pipeline
#
# Usage:
#   # Local testing with Docker
#   snakemake --configfile workflow/config/test_config.yaml --profile workflow/profiles/local
#
#   # Production run on Wynton SGE
#   snakemake --configfile workflow/config/config.yaml --profile workflow/profiles/sge
#
# See README.md for the full guide.

from pathlib import Path


configfile: "workflow/config/config.yaml"


include: "rules/common.smk"
include: "rules/hello.smk"


localrules: list_samples


rule all:
    """Default target: produce one hello.txt per sample."""
    input:
        expand(
            "{output_dir}/{sample}/hello.txt",
            output_dir=config["output_dir"],
            sample=get_all_samples(),
        ),


rule clean:
    """Remove all generated output files."""
    shell:
        "rm -rf {config[output_dir]}"


rule list_samples:
    """Print all configured samples."""
    run:
        print("Configured samples:")
        for sample_id in get_all_samples():
            desc = samples.loc[sample_id, "description"]
            print(f"  - {sample_id}: {desc}")


onstart:
    print(f"{{ cookiecutter.project_slug }} pipeline v{PIPELINE_VERSION}")
    if USE_APPTAINER and config.get("containers", {}).get("auto_pull", True):
        import os, subprocess
        container_dir = config["containers"]["dir"]
        os.makedirs(container_dir, exist_ok=True)
        for image_name in config["containers"]["images"]:
            sif_path = get_apptainer_path(image_name)
            if not os.path.exists(sif_path):
                docker_uri = get_docker_image(image_name)
                print(f"Pulling {docker_uri} -> {sif_path}")
                subprocess.check_call(["apptainer", "pull", sif_path, docker_uri])
            else:
                print(f"Container exists: {sif_path}")


onsuccess:
    import csv
    import socket
    from datetime import timedelta

    benchmarks_dir = Path(config["output_dir"]) / "benchmarks"
    rows = []
    if benchmarks_dir.exists():
        for tsv in sorted(benchmarks_dir.rglob("*.tsv")):
            with open(tsv) as f:
                reader = csv.DictReader(f, delimiter="\t")
                for row in reader:
                    sample = tsv.parent.name if tsv.parent != benchmarks_dir else "-"
                    rule_name = tsv.stem
                    wall_s = float(row["s"])
                    max_rss = float(row.get("max_rss", 0))
                    cpu_time = float(row.get("cpu_time", 0))
                    rows.append((sample, rule_name, wall_s, max_rss, cpu_time))

    if rows:
        total_s = sum(r[2] for r in rows)
        hdr = f"{'Sample':<20} {'Rule':<40} {'Wall time':>12} {'Max RSS (MB)':>14} {'CPU time (s)':>14}"
        sep = "-" * len(hdr)
        print(f"\n{sep}")
        print("PIPELINE RUNTIME SUMMARY")
        print(sep)
        print(hdr)
        print(sep)
        for sample, rule_name, wall_s, max_rss, cpu_time in rows:
            wall_fmt = str(timedelta(seconds=int(wall_s)))
            print(f"{sample:<20} {rule_name:<40} {wall_fmt:>12} {max_rss:>14.1f} {cpu_time:>14.1f}")
        print(sep)
        print(f"{'TOTAL':<20} {'':<40} {str(timedelta(seconds=int(total_s))):>12}")
        print(sep)

    body_lines = [
        f"Pipeline: {{ cookiecutter.project_slug }} v{PIPELINE_VERSION}",
        f"Host: {socket.gethostname()}",
        f"Output: {config['output_dir']}",
        f"Samples: {', '.join(get_all_samples())}",
    ]
    send_notification(
        f"[{{ cookiecutter.project_slug }}] Pipeline completed successfully",
        "\n".join(body_lines),
    )


onerror:
    import socket
    body_lines = [
        f"Pipeline: {{ cookiecutter.project_slug }} v{PIPELINE_VERSION}",
        f"Host: {socket.gethostname()}",
        f"Output: {config['output_dir']}",
        f"Samples: {', '.join(get_all_samples())}",
        f"Log: {log}",
        "",
        "Check the Snakemake log for the failed rule and error details.",
        "Re-run the same command to resume from the failed step.",
    ]
    send_notification(
        f"[{{ cookiecutter.project_slug }}] Pipeline FAILED",
        "\n".join(body_lines),
    )
